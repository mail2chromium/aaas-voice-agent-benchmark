# AaaS Voice Agent Benchmark — Environment Configuration
# Copy this to .env and fill in your API keys

# STT — Deepgram
DEEPGRAM_API_KEY=your_deepgram_key_here

# LLM — OpenAI
OPENAI_API_KEY=your_openai_key_here

# TTS — ElevenLabs
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# Orchestrator — LiveKit
LIVEKIT_URL=wss://your-livekit-instance.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# CRM — Salesforce (optional, for production benchmarks)
SALESFORCE_TOKEN=your_salesforce_token
SALESFORCE_INSTANCE_URL=https://your-instance.salesforce.com

# CRM — HubSpot (alternative)
HUBSPOT_API_KEY=your_hubspot_key

# Calendar — Google (optional)
GOOGLE_CALENDAR_CREDENTIALS=path/to/credentials.json
